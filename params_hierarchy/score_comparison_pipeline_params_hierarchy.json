{
  "pipeline": "ScoreComparisonPipeline",
  "config_class": "ScoreComparisonPipelineConfig",
  "hierarchy": {
    "required": [
      {
        "level1": "基础输入与输出",
        "level2": [
          {
            "name": "输出控制",
            "params": {
              "output_dir": "输出目录，默认 output/score_comparison",
              "random_state": "随机种子，当前主要保留为配置一致性",
              "write_outputs": "是否输出 CSV",
              "write_excel": "是否输出 Excel 报告"
            }
          },
          {
            "name": "标签、分数与权重",
            "params": {
              "target_col": "表现标签字段，默认 badflag",
              "score_cols": "全部评分字段；若为空则使用 base_score + comp_scores",
              "base_score": "基准评分字段",
              "comp_scores": "对比评分字段列表",
              "weight_col": "可选样本权重字段",
              "split_col": "可选评估集字段；接受 ins/oos/oot/ft_oot 等任意非空名称，不做训练切分，只作为默认 group 维度"
            },
            "rules": [
              "必须提供 score_cols 或 base_score + comp_scores",
              "split_col 若配置，值会 strip 并转为小写，且必须至少包含一个非空枚举值"
            ]
          }
        ]
      }
    ],
    "optional": [
      {
        "level1": "全局性能与 Gains 参数",
        "level2": [
          {
            "name": "分箱与样本量",
            "params": {
              "nbins": "评分分箱数",
              "min_bin_prop": "最小箱占比",
              "equal_freq": "是否等频分箱",
              "min_data_size": "分组评估最小样本量",
              "precision": "报表数值精度"
            }
          },
          {
            "name": "缺失与分数口径",
            "params": {
              "include_missing": "分箱/交叉分析是否包含 missing",
              "fillna": "缺失填充值",
              "positive_score_only": "是否按正向分数口径处理"
            }
          },
          {
            "name": "Gains 附加指标",
            "params": {
              "gains_add_func": "自定义 gains 附加指标函数",
              "custom_metric_cols": "默认附加均值指标列",
              "gains_display_metric_list": "gains 报告展示指标列表"
            }
          }
        ]
      },
      {
        "level1": "分组评分对比",
        "level2": [
          {
            "name": "时间与人群维度",
            "params": {
              "time_dims": "时间维度列表，默认 apply_month",
              "population_dims": "人群维度列表，默认 channel",
              "segment_dims": "population_dims 的兼容别名；传入后覆盖 population_dims",
              "include_time_population_cross": "是否自动生成 population x time 交叉分组",
              "group_min_size": "分组最小样本量；为空时继承 min_data_size",
              "group_specs": "显式分组配置；支持命名字典或 name/columns/min_size 列表，传入后覆盖自动 time/population/split 组合"
            }
          },
          {
            "name": "分组缺失值规范化",
            "params": {
              "group_missing_values": "分组字段中视为缺失的 token",
              "drop_missing_group_values": "是否把空字符串等 token 转为 NA 并从默认分组中排除"
            }
          }
        ]
      },
      {
        "level1": "Cross Risk 分析",
        "level2": [
          {
            "name": "单评分 x 交叉变量",
            "params": {
              "cross_vars": "要做 cross_risk 的变量列表；默认空",
              "cross_metrics": "cross_risk 聚合指标；为空时使用 target_col bad_rate 和 custom_metric_cols 均值",
              "cross_binning_numeric": "传给 cross_risk 的 binning_numeric，可为 bool 或列表"
            }
          },
          {
            "name": "多评分两两交叉",
            "params": {
              "pairwise_cross_enabled": "是否调用 get_cross_risk_summary",
              "pairwise_cross_agg_dict": "pairwise cross 聚合字典；为空时使用默认 bad_rate/custom metrics"
            }
          }
        ]
      }
    ]
  },
  "requirement_note": "必填类别包含评分对比必须确认的数据字段入口；必须提供 score_cols 或 base_score + comp_scores。",
  "underlying_method_params": {
    "Model_Evaluation_Tool": {
      "passes_to": "Modeling_Tool.Eval.Evaluation_Tool.Model_Evaluation_Tool",
      "accepted_params": {
        "nbins": {
          "config_key": "nbins"
        },
        "min_bin_prop": {
          "config_key": "min_bin_prop"
        },
        "equal_freq": {
          "config_key": "equal_freq"
        },
        "min_data_size": {
          "config_key": "min_data_size"
        },
        "precision": {
          "config_key": "precision"
        },
        "include_missing": {
          "config_key": "include_missing"
        },
        "fillna": {
          "config_key": "fillna"
        },
        "weight_col": {
          "config_key": "weight_col"
        },
        "positive_score_only": {
          "config_key": "positive_score_only"
        },
        "cross_agg_dict": {
          "config_key": "pairwise_cross_agg_dict or default"
        },
        "gains_display_metric_list": {
          "config_key": "gains_display_metric_list"
        }
      }
    },
    "group_specs": {
      "accepted_forms": [
        "{group_name: [column1, column2]}",
        "[{name: group_name, columns: [column1, column2], min_size: 100}]"
      ],
      "pipeline_schema": {
        "name": {
          "required": false,
          "meaning": "输出 group_perf 的 key"
        },
        "columns": {
          "required": true,
          "meaning": "分组字段列表"
        },
        "min_size": {
          "required": false,
          "default": "group_min_size or min_data_size"
        }
      }
    },
    "cross_metrics": {
      "schema": "{metric_name: [agg_col, agg_func]}",
      "validation": "每个 value 必须是二元组/二元列表；agg_col 必须存在；agg_func 必须是字符串或 callable",
      "example": {
        "bad_rate": [
          "badflag",
          "mean"
        ],
        "credit_limit": [
          "credit_limit",
          "mean"
        ]
      }
    },
    "pairwise_cross_agg_dict": {
      "passes_to": "Model_Evaluation_Tool.get_cross_risk_summary(cross_agg_dict=...)",
      "schema": "{column: agg function 或 list[agg functions]}",
      "validation": "column 必须存在；aggregation 必须是字符串或 callable"
    }
  }
}
