{
  "pipeline": "CreditModelPipeline",
  "config_class": "CreditModelPipelineConfig",
  "hierarchy": {
    "required": [
      {
        "level1": "基础输入与输出",
        "level2": [
          {
            "name": "输出与运行控制",
            "params": {
              "output_dir": "输出目录，默认 output",
              "random_state": "全局随机种子",
              "write_outputs": "是否输出 CSV/图片/解释性文件",
              "write_excel": "是否输出 Excel 报告",
              "plot_outputs": "是否输出 WOE/perf/explain 图片"
            }
          },
          {
            "name": "字段边界",
            "params": {
              "target_col": "建模目标字段，默认 badflag",
              "feature_cols": "原始入模特征；为空时自动选择数值列并排除 target/split/oot/weight",
              "weight_col": "样本权重字段；会传给 GBM 训练、param_search 和评估",
              "extra_eval_datasets": "额外评估数据集字典；key 不能与 ins/oos/oot 冲突"
            }
          }
        ]
      }
    ],
    "optional": [
      {
        "level1": "样本切分",
        "level2": [
          {
            "name": "已有切分字段",
            "params": {
              "split_col": "推荐切分字段；支持 ins/oos/oot，优先级最高",
              "sample_col": "兼容旧切分字段，默认 sample_ind",
              "oot_col": "OOT flag 字段；无 split/sample 字段时使用"
            },
            "rules": [
              "split_col 优先于 sample_col",
              "split_col 必须包含非空 ins 和 oos；若无 oot，则 oot=oos.copy()",
              "无 split/sample 时，先用 oot_col 拆 OOT，再用 split_config 拆 INS/OOS"
            ]
          },
          {
            "name": "随机切分配置",
            "params": {
              "split_config": {
                "test_size": "OOS 比例，默认 0.3",
                "stratify": "是否按 target_col 分层",
                "random_state": "切分随机种子；为空时继承顶层 random_state"
              }
            }
          }
        ]
      },
      {
        "level1": "特征筛选与 FeatureValidation 复用",
        "level2": [
          {
            "name": "内置筛选",
            "params": {
              "feature_selection": {
                "psi_enabled": "是否做 PSI 筛选",
                "psi_threshold": "PSI 阈值",
                "psi_compare_splits": "PSI 对比样本集，默认 ['oos']",
                "iv_enabled": "是否做 IV 筛选",
                "iv_threshold": "IV 阈值",
                "corr_enabled": "是否做相关性筛选",
                "corr_threshold": "相关性阈值",
                "corr_max_iterations": "相关性筛选最大迭代轮数"
              }
            }
          },
          {
            "name": "筛选产物复用",
            "params": {
              "screening_artifact": "显式传入 FeatureScreeningArtifact",
              "feature_validation_result": "传入 FeatureValidationPipelineResult 后转成 screening artifact",
              "feature_selection_mode": "run/from_artifact/skip；控制是重新筛选、复用产物还是跳过筛选",
              "reuse_screening_woe": "是否复用 screening artifact 中的 WOE artifact"
            },
            "rules": [
              "screening_artifact 优先于 feature_validation_result",
              "from_artifact 依赖已有筛选产物",
              "skip 会绕过筛选，直接使用 feature_cols"
            ]
          }
        ]
      },
      {
        "level1": "WOE 分箱",
        "level2": [
          {
            "name": "WOE 总配置",
            "params": {
              "woe_engine": "equal_freq 或 monotone，默认 equal_freq",
              "woe_fit_query": "WOE fit 前对 INS 样本的过滤条件",
              "woe_params": {
                "nbins": "equal_freq 分箱数",
                "equal_freq": "是否等频",
                "min_bin_prop": "最小箱占比",
                "woe_suffix": "WOE 后缀，可选"
              },
              "monotone_woe_params": {
                "n_init_bins": "monotone 初始箱数",
                "min_bin_size": "monotone 最小箱占比",
                "min_n_bins": "monotone 最小箱数"
              }
            }
          },
          {
            "name": "WOE 与模型特征来源",
            "params": {
              "gbm_feature_source": "woe/raw 或按模型配置的 dict；LR 永远使用 WOE"
            },
            "rules": [
              "默认所有模型使用 WOE 特征，保持旧行为",
              "gbm_feature_source='raw' 时 lgb/xgb/cat 使用原始特征",
              "dict key 只允许 lgb/xgb/cat，value 只允许 raw/woe",
              "raw 模式不自动做类别编码"
            ]
          }
        ]
      },
      {
        "level1": "模型训练",
        "level2": [
          {
            "name": "模型集合与参数",
            "params": {
              "train_models": "要训练的模型列表，默认 lr/lgb/xgb/cat",
              "model_params": "各模型参数覆盖，例如 {'lgb': {...}, 'lr': {...}}"
            }
          },
          {
            "name": "LR 参数搜索",
            "params": {
              "lr_search_enabled": "是否对 LR 做 grid_search_params",
              "lr_search_param_grid": "LR 参数网格，默认 C=[0.01,0.1,1.0,10.0]",
              "lr_search_params": "LR search 额外参数覆盖",
              "use_lr_search_params": "是否把搜索到的 best_params 合并进最终 LR 训练"
            },
            "rules": [
              "只有 train_models 包含 lr 且 lr_search_enabled=true 时运行",
              "搜索在 WOE 特征上进行"
            ]
          },
          {
            "name": "GBM warm-start",
            "params": {
              "warm_start_enabled": "是否启用前置分 warm-start",
              "warm_start_score_col": "前置分字段",
              "warm_start_score_type": "probability 或 log_odds",
              "warm_start_models": "应用 warm-start 的模型，默认 lgb/xgb",
              "warm_start_on_unsupported": "遇到不支持模型时 skip 或 raise",
              "warm_start_apply_to_optuna": "warm-start 是否参与 GBM optuna refit/search"
            },
            "rules": [
              "warm_start_enabled=true 时必须提供 warm_start_score_col",
              "当前只支持 lgb/xgb；cat 默认 skip",
              "probability 会先裁剪再转 log_odds"
            ]
          }
        ]
      },
      {
        "level1": "逐步回归、Optuna 与解释性",
        "level2": [
          {
            "name": "Backward",
            "params": {
              "backward_enabled": "是否运行 backward feature selection",
              "backward_model": "逐步回归使用的模型，默认 lgb",
              "backward_params": "逐步回归参数覆盖",
              "use_backward_features": "最终模型是否使用 backward 选择后的特征"
            },
            "rules": [
              "backward 默认在 WOE 特征上运行",
              "GBM raw 模式且 use_backward_features=true 时，会把选出的 _woe 特征映射回原始列"
            ]
          },
          {
            "name": "Optuna",
            "params": {
              "optuna_models": "需要做 Optuna 的 GBM 模型，默认 lgb/xgb/cat",
              "optuna_n_trials": "Optuna trial 数",
              "optuna_params": "Optuna search_spaces/common/fit_kwargs 等覆盖参数"
            }
          },
          {
            "name": "解释性",
            "params": {
              "explain_models": "需要跑 SHAP/LIME/PDP 等解释性的模型列表",
              "explain_params": "解释性参数，例如 sample_n/background_n/owen_*",
              "owen_enabled": "是否跑 Owen coalition 解释",
              "business_prior_groups": "Owen 业务先验分组"
            }
          }
        ]
      },
      {
        "level1": "性能评估与模型落盘",
        "level2": [
          {
            "name": "PerformanceEvaluator",
            "params": {
              "perf_pct_bins": "性能评估分箱数",
              "perf_min_bin_prop": "性能评估最小箱占比"
            }
          },
          {
            "name": "模型持久化",
            "params": {
              "save_models": "是否保存模型 pkl 和 WOE artifact",
              "model_output_dir": "模型输出目录；为空时使用 output_dir/models",
              "model_include_metadata": "是否保存 metadata envelope",
              "save_woe_artifacts": "是否保存 WOE table/engine 等 artifact"
            }
          }
        ]
      }
    ]
  },
  "requirement_note": "必填类别包含运行建模必须确认的数据字段入口；输出路径等虽然有默认值，但保留在原一级类别中。",
  "underlying_method_params": {
    "split_config": {
      "source": "Modeling_Tool.Sample.Sample_Split.SampleSplitter",
      "constructor": {
        "test_size": {
          "default": 0.3,
          "meaning": "测试/OOS 样本比例"
        },
        "random_state": {
          "default": null,
          "meaning": "随机种子"
        },
        "stratify": {
          "default": true,
          "meaning": "是否按 target 分层抽样"
        }
      },
      "methods": {
        "split_df": {
          "target": {
            "required": true,
            "meaning": "分层目标字段"
          },
          "exclude_cols": {
            "default": null,
            "meaning": "不参与切分策略的列，不会从输出 DataFrame 删除"
          },
          "test_size": {
            "default": null,
            "meaning": "覆盖 constructor test_size"
          }
        }
      }
    },
    "feature_selection": {
      "passes_to": "Modeling_Tool.Feature.Feature_Screen.screen_config_from_mapping / feature_screen",
      "accepted_params": {
        "psi_enabled": {
          "default": true
        },
        "psi_threshold": {
          "default": 0.2
        },
        "psi_compare_splits": {
          "default": [
            "oos"
          ]
        },
        "psi_buckets": {
          "default": 10
        },
        "psi_use_woe_bins": {
          "default": false
        },
        "iv_enabled": {
          "default": true
        },
        "iv_threshold": {
          "default": 0.02
        },
        "iv_nbins": {
          "alias": "iv_bins",
          "default": 10
        },
        "iv_min_bin_prop": {
          "default": 0.05
        },
        "iv_equal_freq": {
          "default": true
        },
        "iv_use_woe_bins": {
          "default": false
        },
        "corr_enabled": {
          "default": true
        },
        "corr_threshold": {
          "default": 0.75
        },
        "corr_max_iterations": {
          "default": 10
        },
        "corr_use_woe_bins": {
          "default": false
        },
        "corr_nan_policy": {
          "default": "pairwise",
          "allowed": [
            "pairwise",
            "median_fill",
            "raise"
          ]
        },
        "on_empty_stage": {
          "default": "keep_all_warn",
          "allowed": [
            "keep_all_warn",
            "raise"
          ]
        },
        "missing_rate_threshold": {
          "default": null
        },
        "missing_rate_ref": {
          "default": -999999
        },
        "content": {
          "default": 1e-06
        },
        "precision": {
          "default": 5
        },
        "min_bin_prop": {
          "default": 0.05
        }
      }
    },
    "woe_params": {
      "source": "Modeling_Tool.WOE.WOE_Master.WOE_Master",
      "constructor": {
        "train_data": {
          "controlled_by_pipeline": true
        },
        "varlist": {
          "controlled_by_pipeline": true
        },
        "dep": {
          "controlled_by_pipeline": true
        },
        "graph_save_dir": {
          "controlled_by_pipeline": true
        },
        "woe_suffix": {
          "default": "_woe",
          "config_key": "woe_params.woe_suffix"
        },
        "missing_ref_value": {
          "default": "SMF_MISSING_BIN / -999999 by pipeline",
          "config_key": "woe_params.missing_ref_value"
        },
        "remove_exist_dir": {
          "default": false,
          "meaning": "初始化时是否删除已有图目录"
        }
      },
      "fit": {
        "nbins": {
          "default": 10,
          "meaning": "分箱数"
        },
        "equal_freq": {
          "default": true,
          "meaning": "是否等频"
        },
        "tree_binning_seed": {
          "default": null,
          "meaning": "传入整数时启用树分箱并指定随机种子"
        },
        "chi2_config": {
          "default": null,
          "meaning": "卡方分箱配置，通常为 (init_equi_bins, chi2_p)"
        },
        "precision": {
          "default": 5,
          "meaning": "边界/报表精度"
        },
        "min_bin_prop": {
          "default": 0.05,
          "meaning": "最小箱占比"
        },
        "include_missing": {
          "default": true,
          "meaning": "是否单独包含缺失箱"
        },
        "fillna": {
          "default": null,
          "meaning": "缺失填充值；None 时使用 missing_ref_value"
        },
        "spec_values": {
          "default": [],
          "meaning": "特殊值列表"
        }
      }
    },
    "monotone_woe_params": {
      "source": "Modeling_Tool.WOE.WOE_Monotone_Binner.MonotoneWOEBinner",
      "constructor": {
        "feature_cols": {
          "controlled_by_pipeline": true,
          "meaning": "数值特征；categorical_features 会从中剔除"
        },
        "target_col": {
          "controlled_by_pipeline": true
        },
        "n_init_bins": {
          "default": 20,
          "meaning": "初始等频箱数"
        },
        "min_bin_size": {
          "default": 0.03,
          "meaning": "每箱最小样本占比"
        },
        "min_n_bins": {
          "default": 2,
          "meaning": "最终普通箱数下限"
        },
        "eps": {
          "default": 1e-06,
          "meaning": "WOE 平滑项，防止 log(0)"
        },
        "missing_woe": {
          "default": 0.0,
          "meaning": "未作为 special_values 的 NaN 对应 WOE"
        },
        "special_values": {
          "default": null,
          "meaning": "需要单独成箱的特殊值"
        },
        "cate_feats": {
          "default": null,
          "meaning": "类别特征；Pipeline 由 categorical_features 映射"
        },
        "bin_label_decimals": {
          "default": null,
          "meaning": "分箱边界展示小数位"
        }
      },
      "fit": {
        "chi2_binning": {
          "default": false,
          "meaning": "贪婪单调分箱后是否再做卡方合并"
        },
        "chi2_p": {
          "default": 0.99,
          "meaning": "卡方检验置信度阈值"
        },
        "chi2_init_size": {
          "default": 1000,
          "meaning": "卡方计算时分层抽样上限"
        },
        "n_jobs": {
          "default": 1,
          "meaning": "并行数；-1 表示所有可用 CPU"
        }
      },
      "refine_cate": {
        "features": {
          "default": null,
          "pipeline_default": "categorical_features 中存在于 fit_features 的列",
          "meaning": "要聚类的类别特征"
        },
        "max_bins": {
          "default": 5,
          "meaning": "类别聚类后的最大箱数"
        },
        "min_bin_size": {
          "default": 0.0,
          "meaning": "低于该样本占比的小箱会优先合并"
        },
        "badrate_tol": {
          "default": null,
          "meaning": "相邻类别坏账率差阈值；None 表示不启用"
        }
      },
      "refine_dtree": {
        "df": {
          "controlled_by_pipeline": true,
          "meaning": "WOE fit 使用的训练数据"
        },
        "features": {
          "default": null,
          "pipeline_default": "数值特征列表",
          "meaning": "要重分箱的数值特征"
        },
        "max_bins": {
          "default": 6,
          "meaning": "决策树最大叶子数，即分箱上限"
        },
        "min_samples_leaf": {
          "default": 0.05,
          "meaning": "叶子最小样本占比或绝对样本量"
        },
        "monotone": {
          "default": true,
          "meaning": "树分箱后是否强制 WOE 单调"
        },
        "n_jobs": {
          "default": 1,
          "meaning": "并行进程数；-1 表示所有可用 CPU"
        }
      },
      "refine_chi2": {
        "df": {
          "controlled_by_pipeline": true,
          "meaning": "WOE fit 使用的训练数据"
        },
        "features": {
          "default": null,
          "pipeline_default": "数值特征列表",
          "meaning": "要做卡方后合并的数值特征"
        },
        "chi2_p": {
          "default": 0.99,
          "meaning": "卡方检验置信度阈值"
        },
        "chi2_init_size": {
          "default": 1000,
          "meaning": "卡方计算时分层抽样上限"
        },
        "n_jobs": {
          "default": 1,
          "meaning": "并行数；-1 表示所有可用 CPU"
        }
      },
      "pipeline_note": "CreditModelPipeline 当前把 monotone_woe_params 直接传给 MonotoneWOEBinner 构造器，并仅显式读取 chi2_binning 传给 fit；除默认构造器参数外的 fit-only key 需谨慎。"
    },
    "model_params": {
      "passes_to": "Modeling_Tool.Model.GBM_Tool.GradientBoostingModel / LRMaster",
      "accepted_params": {
        "lr": {
          "passes_to": "LRMaster(params=...)",
          "library": "sklearn.linear_model.LogisticRegression 参数，例如 C/penalty/solver/max_iter/class_weight"
        },
        "lgb": {
          "passes_to": "lightgbm.LGBMClassifier 参数，例如 n_estimators/learning_rate/num_leaves/max_depth/subsample/colsample_bytree/reg_alpha/reg_lambda/n_jobs/early_stopping_rounds/eval_metric"
        },
        "xgb": {
          "passes_to": "xgboost.XGBClassifier 参数，例如 n_estimators/learning_rate/max_depth/min_child_weight/subsample/colsample_bytree/reg_alpha/reg_lambda/n_jobs/eval_metric"
        },
        "cat": {
          "passes_to": "catboost.CatBoostClassifier 参数，例如 iterations/learning_rate/depth/l2_leaf_reg/random_seed/eval_metric/allow_writing_files/train_dir"
        }
      }
    },
    "lr_search_params": {
      "passes_to": "LRMaster.grid_search_params",
      "accepted_params": {
        "objective": {
          "default": "oot_gap_penalized",
          "allowed": [
            "oot_gap_penalized",
            "max_primary",
            "callable"
          ]
        },
        "primary_set": {
          "default": "oos in pipeline defaults"
        },
        "gap_ref_sets": {
          "default": [
            "oot"
          ]
        },
        "metric": {
          "default": "auc",
          "allowed": [
            "auc"
          ]
        },
        "refit": {
          "default": false
        },
        "verbose": {
          "default": false
        },
        "weight_col": {
          "default": "顶层 weight_col"
        },
        "eval_weight_col": {
          "default": "顶层 weight_col"
        }
      },
      "param_grid": "lr_search_param_grid 传入 LRMaster.grid_search_params(param_grid=...)"
    },
    "optuna_params": {
      "passes_to": "GradientBoostingModel.param_search",
      "accepted_params": {
        "search_spaces": {
          "default": "Pipeline 内置 lgb/xgb/cat search space"
        },
        "common": {
          "engine": {
            "default": "optuna"
          },
          "objective": {
            "default": "oot_gap_penalized"
          },
          "primary_set": {
            "default": "oos"
          },
          "gap_ref_sets": {
            "default": [
              "oot"
            ]
          },
          "metric": {
            "default": "auc"
          },
          "n_trials": {
            "default": "optuna_n_trials"
          },
          "refit": {
            "default": true
          },
          "verbose": {
            "default": false
          },
          "random_state": {
            "default": "顶层 random_state"
          }
        },
        "fit_kwargs": {
          "default": {},
          "meaning": "透传给 GBM fit；warm_start_apply_to_optuna=true 时会注入 init_score"
        }
      }
    },
    "backward_params": {
      "passes_to": "Modeling_Tool.Model.Backward_Tool.BackwardVariableEliminator.run",
      "accepted_params": {
        "n_rounds": {
          "default": 5
        },
        "varreduct_params": {
          "default": null,
          "meaning": "底层 lgb/xgb 参数"
        },
        "stopping_metric": {
          "default": "auc"
        },
        "seed": {
          "default": 42
        },
        "num_boost_round": {
          "default": 200
        },
        "early_stopping_rounds": {
          "default": 20
        },
        "importance_type": {
          "default": "gain"
        },
        "cum_importance_threshold": {
          "default": 0.99
        },
        "min_vars": {
          "default": 10
        },
        "ret_perf": {
          "default": true
        },
        "nbins": {
          "default": 10
        }
      }
    },
    "explain_params": {
      "passes_to": "ModelExplainer and Owen coalition helpers",
      "accepted_params": {
        "sample_n": {
          "default": 500,
          "meaning": "解释性评估样本数"
        },
        "background_n": {
          "default": 200,
          "meaning": "SHAP background 样本数"
        },
        "owen_threshold": {
          "default": 0.35
        },
        "owen_method": {
          "default": "complete"
        },
        "owen_corr_method": {
          "default": "spearman"
        },
        "owen_min_group_size": {
          "default": 1
        },
        "owen_intra_dist": {
          "default": 0.01
        },
        "owen_inter_dist": {
          "default": 0.99
        },
        "owen_model_output": {
          "default": "probability"
        }
      }
    }
  }
}
